Ps_ep_U[Ps_dim,Ps_dim]<-Ps_ep_surv[8]
Ps_em<-lifeTimeRepEvents(Ps_em_U,Ps_em_F,2)
Ps_ep<-lifeTimeRepEvents(Ps_ep_U,Ps_ep_F,2)
##store outputs
Ps_lifehistorypost$R0_em[i]<-Ps_em$Ro
